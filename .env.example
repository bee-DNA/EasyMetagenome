# Host absolute paths (edit these before running)
WORK_DIR=/path/to/work
SEQ_DIR=/path/to/work/seq
RESULT_DIR=/path/to/work/result
TEMP_DIR=/path/to/work/temp
LOG_DIR=/path/to/work/log
DB_DIR=/path/to/db

# Runtime parameters
THREADS=16

# metadata auto-generation switch for visualization script
# 0: disable (recommended), 1: enable
AUTO_METADATA=0
